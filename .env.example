# ─── Required ─────────────────────────────────────────────────────────────────
# Strong password for the bundled Postgres instance.
POSTGRES_PASSWORD=

# JWT signing secret. Generate with: openssl rand -hex 32
SECRET_KEY=


# ─── Optional ─────────────────────────────────────────────────────────────────
# Database — only override if you need non-default user/db name.
POSTGRES_USER=testjam
POSTGRES_DB=testjam

# How long an access token is valid (minutes).
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Host port mapped to the web container. Point your reverse proxy here.
APP_PORT=8080

# Redis URL for realtime pubsub backplane. Required for multi-worker WS fan-out.
# Defaults to the bundled redis service in docker-compose.
# Set to an empty string to opt out (only safe with a single API worker).
REDIS_URL=redis://redis:6379/0


# ─── Dev-only (docker-compose-dev.yml) ────────────────────────────────────────
# Only used by `docker compose -f docker-compose-dev.yml up`.
POSTGRES_PORT=5432
API_PORT=8000
REDIS_PORT=6379
FRONTEND_PORT=5173
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025

# E2E
TESTJAM_USER=admin
TESTJAM_PASS=admin123
TESTJAM_PROJECT=Testjam E2E
